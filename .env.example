# --- Resend (contact form e-mail delivery) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact-form submissions.
# Optional — defaults to kontakt@360connect.pl
CONTACT_EMAIL=kontakt@360connect.pl

# Sender shown on outgoing e-mails. The domain MUST be verified in Resend.
# Optional — defaults to "360 Connect <noreply@360connect.pl>"
RESEND_FROM_EMAIL="360 Connect <noreply@360connect.pl>"

# --- Contentful (existing) ---
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=

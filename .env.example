# --- Resend (contact form e-mail delivery) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact-form submissions.
# Optional — defaults to kontakt@360connect.com.pl
CONTACT_EMAIL=kontakt@360connect.com.pl

# Sender shown on outgoing e-mails. The domain MUST be verified in Resend
# (the verified domain is 360connect.com.pl).
# Optional — defaults to "360 Connect <noreply@360connect.com.pl>"
RESEND_FROM_EMAIL="360 Connect <noreply@360connect.com.pl>"

# --- Contentful (existing) ---
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
